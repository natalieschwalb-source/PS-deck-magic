# Recommended: Google Gemini (text + Nano Banana / Imagen images + optional Veo video)
GEMINI_API_KEY=
# Optional explicit provider: gemini | openai (default: gemini if GEMINI_API_KEY is set)
# AI_PROVIDER=gemini

GEMINI_MODEL=gemini-2.5-flash
# Nano Banana (native Gemini image). Try gemini-3.1-flash-image-preview if your key supports it.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Or use Imagen instead: GEMINI_IMAGE_BACKEND=imagen and optionally:
# GEMINI_IMAGEN_MODEL=imagen-4.0-fast-generate-001

# Veo video clips (slow, paid). Serves files under /clips/
# GEMINI_ENABLE_VEO=1
# GEMINI_VIDEO_MODEL=veo-3.1-generate-preview
# GEMINI_VIDEO_TIMEOUT_MS=480000

# Legacy: OpenAI (only if AI_PROVIDER=openai or no Gemini key)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_IMAGE_MODEL=gpt-image-1

# PORT=5179
# HTTP_TIMEOUT_MS=600000
# JSON_BODY_LIMIT=32mb
# Retries for Gemini 503/429 (optional)
# GEMINI_RETRY_MAX=4
# GEMINI_RETRY_BASE_MS=1500
# Fallback text models (comma-separated) if primary model is under high demand
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash-lite

# Brand website analyzer (Phase 3 → Analyze site)
# BRAND_SITE_FETCH_MS=22000
# BRAND_SITE_MAX_BYTES=1200000
